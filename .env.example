# Video Translator Configuration
# Copy this file to .env and customize as needed

# ==================== Model Configuration ====================

# ASR Model: Qwen/Qwen3-ASR-1.7B or Qwen/Qwen3-ASR-0.6B
QWEN_ASR_MODEL=Qwen/Qwen3-ASR-1.7B

# TTS Model: Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice or Qwen/Qwen3-TTS-25Hz-0.6B-Base
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice

# Forced Aligner Model
QWEN_ALIGNER_MODEL=Qwen/Qwen3-ForcedAligner-0.6B

# ==================== Hardware Configuration ====================

# Device: cuda, mps, cpu, or auto (recommended)
DEVICE=auto

# Model precision: bf16 (recommended), fp16, or fp32
PRECISION=bf16

# Enable FlashAttention 2 for faster inference (requires flash-attn package)
FLASH_ATTENTION=true

# ==================== Storage Configuration ====================

# Directory to cache downloaded models
MODEL_CACHE_DIR=./models_cache

# Directory for output files
OUTPUT_DIR=./output

# Directory for temporary files
TEMP_DIR=/tmp/video_translator

# ==================== API Configuration ====================

# API server host
API_HOST=0.0.0.0

# API server port
API_PORT=8000

# API key for authentication (optional, leave empty for no auth)
API_KEY=

# ==================== Queue Configuration ====================

# Redis connection URL for task queue
REDIS_URL=redis://localhost:6379

# Number of Celery workers
CELERY_WORKERS=2

# ==================== Translation Configuration ====================

# Default target language (ISO 639-1 code)
TARGET_LANGUAGE=es

# ==================== Processing Configuration ====================

# Audio sample rate for processing (Hz)
AUDIO_SAMPLE_RATE=16000

# Number of audio channels (1=mono, 2=stereo)
AUDIO_CHANNELS=1

# Maximum audio duration per segment (seconds)
MAX_AUDIO_DURATION=1200

# Voice Activity Detection threshold
VAD_THRESHOLD=0.5
